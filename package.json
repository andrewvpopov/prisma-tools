{
  "name": "@andrewpopov/prisma-tools",
  "version": "0.4.1",
  "description": "Reusable Prisma environment, schema, and command wrapper utilities",
  "author": "Andrew Popov",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewpopov/prisma-tools.git"
  },
  "bugs": { "url": "https://github.com/andrewpopov/prisma-tools/issues" },
  "homepage": "https://github.com/andrewpopov/prisma-tools#readme",
  "keywords": [
    "prisma",
    "cli",
    "sqlite",
    "postgres",
    "environment",
    "wrapper"
  ],
  "bin": {
    "prisma-tools": "src/cli.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "verify:pack": "node scripts/verify-pack.mjs",
    "verify:types": "tsc --noEmit -p tsconfig.types.json",
    "verify": "npm run verify:types && npm test && npm run verify:pack && npm audit --omit=dev --audit-level=high"
  },
  "dependencies": {
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
